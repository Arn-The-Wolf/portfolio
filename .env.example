# Required for admin login (/admin) — use strong unique values in production
ADMIN_PASSWORD=change-me
ADMIN_SECRET=change-me-to-a-long-random-string

# Public site URL (used in metadata when set)
NEXT_PUBLIC_BASE_URL=https://arnold-rho.vercel.app

# Contact form email (https://resend.com)
RESEND_API_KEY=
# Inbox for contact form submissions (your public email)
CONTACT_TO_EMAIL=ruyangearnold@gmail.com
# Resend account email — receives mail while using onboarding@resend.dev (auto-routed in code)
RESEND_ACCOUNT_EMAIL=arnwolfie5@gmail.com
# After domain verification at resend.com/domains, use your domain here for direct delivery:
RESEND_FROM_EMAIL=ARNOLD.DEV Portfolio <onboarding@resend.dev>

# Optional: GitHub API (higher rate limits)
GITHUB_USERNAME=Arn-The-Wolf
GITHUB_TOKEN=

# Vercel Blob — leave Custom Environment Variable Prefix EMPTY when connecting the store.
# If prefixed, these names also work:
# BLOB_READ_WRITE_TOKEN_READ_WRITE_TOKEN=
# BLOB_READ_WRITE_TOKEN_STORE_ID=
BLOB_READ_WRITE_TOKEN=

# After connecting Blob, seed production CMS data once:
# npm run seed:blob
